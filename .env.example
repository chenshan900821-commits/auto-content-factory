# 环境变量配置

# This project is generated by AI self-evolution.

# ==================== LLM 配置（多提供商支持） ====================

# 选择 LLM 提供商（bailian | zhipu | minimax | moonshot | deepseek | openai | anthropic | google）
LLM_PROVIDER=bailian

# 通用 API Key（如果只使用一个提供商，用这个）
LLM_API_KEY=your-api-key-here

# 自定义 API 地址（可选，覆盖提供商默认地址）
# LLM_BASE_URL=https://custom-api.example.com/v1

# 指定模型（可选，不填则使用提供商默认模型）
# LLM_MODEL=qwen3.5-plus

# ----- 各提供商独立 API Key（推荐方式） -----

# 阿里云百炼（默认）
# 获取地址：https://dashscope.console.aliyun.com
BAILIAN_API_KEY=your-bailian-api-key

# 智谱 AI
# 获取地址：https://open.bigmodel.cn
ZHIPU_API_KEY=your-zhipu-api-key

# MiniMax
# 获取地址：https://api.minimax.chat
MINIMAX_API_KEY=your-minimax-api-key

# 月之暗面（Kimi）
# 获取地址：https://api.moonshot.cn
MOONSHOT_API_KEY=your-moonshot-api-key

# 深度求索（DeepSeek）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI
# 获取地址：https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key

# Anthropic (Claude)
# 获取地址：https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
# 获取地址：https://aistudio.google.com
GOOGLE_API_KEY=your-google-api-key

# ==================== 微信公众号配置 ====================

# 微信公众号 AppID
WECHAT_APP_ID=your-wechat-app-id

# 微信公众号 AppSecret
WECHAT_APP_SECRET=your-wechat-app-secret

# 图文草稿默认作者（可选）
# WECHAT_ARTICLE_AUTHOR=AutoContent Factory

# 封面图：二选一即可
# 1）在请求里传 cover_image（≤64KB 的 http(s) 图片 URL），会先下载再上传为 thumb 素材
# 2）或在公众平台上传好封面后，把永久素材的 thumb_media_id 填在这里（推荐生产环境）
# WECHAT_DEFAULT_THUMB_MEDIA_ID=

# 一键生成微信文章时未传 cover_image 时使用的默认封面图 URL（可选，仍须 ≤64KB）
# WECHAT_DEFAULT_COVER_IMAGE_URL=

# ==================== YouTube 配置 ====================

# YouTube Data API Key（仅用于 list_videos / 趋势等「只读」接口）
# 获取地址：https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key-here

# YouTube 频道 ID
YOUTUBE_CHANNEL_ID=your-channel-id-here

# 上传 / 删除视频必须使用 OAuth2（refresh token）
# 在 Google Cloud Console 创建 OAuth 客户端，完成一次授权后拿到 refresh_token
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost

# ==================== Twitter（真实趋势，可选） ====================

# Twitter API Bearer Token（用于 1.1 trends/place；若未配置则趋势列表为空）
# TWITTER_BEARER_TOKEN=
# 全球 WOEID 默认为 1；可按需改为地区，例如 23424977（美国）
# TWITTER_WOEID=1

# ==================== 视频生成配置 ====================

# 视频生成服务商（d-id / heygen / synthesia）
VIDEO_PROVIDER=d-id

# 视频生成 API Key
# D-ID: https://www.d-id.com
# HeyGen: https://www.heygen.com
VIDEO_API_KEY=your-video-api-key-here

# D-ID 数字人形象图（公开可访问 URL，建议配置为你的素材地址）
# D_ID_SOURCE_URL=https://example.com/avatar.jpg

# 图文视频（slideshow）：由你自建 Webhook 生成，POST JSON { script, type }，返回 { video_url }
# SLIDESHOW_WEBHOOK_URL=
# SLIDESHOW_WEBHOOK_TIMEOUT_MS=120000

# ==================== 调试配置 ====================

# 本地开发时可开启 MOCK_MODE，避免真实调用外部 API
# MOCK_MODE=true
