# 环境变量配置

# ==================== AI 配置 ====================

# 阿里云百炼 API Key
# 获取地址：https://dashscope.console.aliyun.com
LLM_API_KEY=your-llm-api-key-here

# 阿里云百炼 API 地址
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI 模型（可选）
LLM_MODEL=qwen-plus

# ==================== YouTube 配置 ====================

# YouTube Data API Key
# 获取地址：https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key-here

# YouTube 频道 ID
YOUTUBE_CHANNEL_ID=your-channel-id-here

# ==================== 视频生成配置 ====================

# 视频生成服务商（d-id / heygen / synthesia）
VIDEO_PROVIDER=d-id

# 视频生成 API Key
# D-ID: https://www.d-id.com
# HeyGen: https://www.heygen.com
VIDEO_API_KEY=your-video-api-key-here

# ==================== 微信配置（可选） ====================

# 微信公众号 AppID
WECHAT_APP_ID=your-wechat-app-id

# 微信公众号 AppSecret
WECHAT_APP_SECRET=your-wechat-app-secret

# ==================== 新榜 API（可选） ====================

# 新榜 API Key
# 获取地址：https://www.newrank.cn
XINBANG_API_KEY=your-xinbang-api-key
